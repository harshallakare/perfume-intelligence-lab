# ─────────────────────────────────────────────────────────────────────────────
# Perfume Intelligence Lab — Docker environment variables
# Copy to .env.docker and fill in your values:
#   cp .env.docker.example .env.docker
# ─────────────────────────────────────────────────────────────────────────────

# ── MySQL ─────────────────────────────────────────────────────────────────────
MYSQL_ROOT_PASSWORD=change_me_root_password
MYSQL_DATABASE=pil
MYSQL_USER=pil
MYSQL_PASSWORD=change_me_app_password

# Set to a port number to expose MySQL externally (e.g. for GUI clients).
# Leave commented out in production to keep DB internal-only.
# MYSQL_EXTERNAL_PORT=3306

# ── App ───────────────────────────────────────────────────────────────────────
# NODE_ENV is set to "production" automatically inside the container.
# DATABASE_URL is assembled from the MySQL vars above — no need to set it here.
